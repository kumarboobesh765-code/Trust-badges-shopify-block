<div class="trust-badges-section">
  <style>
    .trust-badges-section {
      --tb-bg: transperant;
      --tb-border: #e8e0d0;
      --tb-text: #1c1c1c;
      --tb-sub: #888070;
      --tb-accent: #2d2d2d;
      --tb-gold: #c8860a;
      font-family: inherit;
      background: var(--tb-bg);
      border-top: 1px solid var(--tb-border);
      border-bottom: 1px solid var(--tb-border);
      padding: 20px 16px;
      margin: 20px 0;
    }

    .tb-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }

    @media screen and (max-width: 600px) {
      .tb-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 0;
      }
      .tb-item:nth-child(1),
      .tb-item:nth-child(2) {
        border-bottom: 1px solid var(--tb-border);
        padding-bottom: 18px;
      }
      .tb-item:nth-child(3),
      .tb-item:nth-child(4) {
        padding-top: 18px;
      }
    }

    .tb-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 4px 12px;
      position: relative;
    }

    .tb-item:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 10%;
      height: 80%;
      width: 1px;
      background: var(--tb-border);
    }

    @media screen and (max-width: 600px) {
      .tb-item:nth-child(2)::after { display: none; }
      .tb-item:nth-child(3)::after { display: block; }
    }

    .tb-icon-wrap {
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 10px;
      position: relative;
    }

    .tb-icon-wrap svg {
      width: 42px;
      height: 42px;
      stroke: var(--tb-accent);
      fill: none;
      stroke-width: 1.4;
      stroke-linecap: round;
      stroke-linejoin: round;
      transition: stroke 0.2s;
    }

    .tb-item:hover .tb-icon-wrap svg {
      stroke: var(--tb-gold);
    }

    .tb-title {
      font-size: 12px;
      font-weight: 600;
      color: var(--tb-text);
      margin: 0 0 3px;
      line-height: 1.4;
      letter-spacing: 0.01em;
    }

    .tb-sub {
      font-size: 11px;
      color: var(--tb-sub);
      margin: 0;
      line-height: 1.4;
    }
  </style>

  <div class="tb-grid">

    <!-- Free Shipping -->
    <div class="tb-item">
      <div class="tb-icon-wrap">
        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <!-- Truck body -->
          <rect x="3" y="16" width="28" height="18" rx="2"/>
          <!-- Truck cab -->
          <path d="M31 22h8l4 6v6h-12V22z"/>
          <!-- Wheels -->
          <circle cx="11" cy="36" r="4" stroke-width="1.8"/>
          <circle cx="36" cy="36" r="4" stroke-width="1.8"/>
          <!-- Windshield -->
          <path d="M31 23h6l3 4.5"/>
          <!-- Checkmark badge -->
          <circle cx="40" cy="14" r="6" fill="white" stroke-width="1.4"/>
          <polyline points="37,14 39,16 43,12" stroke-width="1.8"/>
        </svg>
      </div>
      <p class="tb-title">Free Shipping</p>
      <p class="tb-sub">On orders above ₹1499</p>
    </div>

    <!-- Easy Returns -->
    <div class="tb-item">
      <div class="tb-icon-wrap">
        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <!-- Box -->
          <rect x="10" y="18" width="28" height="22" rx="2"/>
          <!-- Box top flap -->
          <polyline points="10,18 24,11 38,18"/>
          <!-- Center crease -->
          <line x1="24" y1="11" x2="24" y2="18"/>
          <!-- Return arrow -->
          <path d="M18 30 Q24 24 30 30" stroke-dasharray="0"/>
          <polyline points="15,28 18,31 21,28"/>
        </svg>
      </div>
      <p class="tb-title">Easy Returns</p>
      <p class="tb-sub">Hassle-free 7-day policy</p>
    </div>

    <!-- Secure Payment -->
    <div class="tb-item">
      <div class="tb-icon-wrap">
        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <!-- Card body -->
          <rect x="6" y="13" width="36" height="24" rx="3"/>
          <!-- Stripe -->
          <line x1="6" y1="20" x2="42" y2="20" stroke-width="4"/>
          <!-- Chip dots -->
          <rect x="11" y="26" width="8" height="5" rx="1"/>
          <!-- Shield -->
          <path d="M32 25 L36 27 L36 32 Q36 35 32 37 Q28 35 28 32 L28 27 Z" fill="white" stroke-width="1.3"/>
          <polyline points="30,32 31.5,33.5 34,30" stroke-width="1.6"/>
        </svg>
      </div>
      <p class="tb-title">Secure Payment</p>
      <p class="tb-sub">100% safe checkout</p>
    </div>

    <!-- COD Available -->
    <div class="tb-item">
      <div class="tb-icon-wrap">
        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <!-- Hand -->
          <path d="M10 28 Q10 38 20 40 L32 40 Q40 40 40 32 L40 24 Q40 22 38 22 L34 22 L34 18 Q34 15 31 15 Q28 15 28 18 L28 22 L26 22 L26 20 Q26 17 23 17 Q20 17 20 20 L20 22 Q18 22 18 24 L18 28"/>
          <!-- Coins/notes on hand -->
          <ellipse cx="30" cy="18" rx="5" ry="3" stroke-width="1.3"/>
          <line x1="25" y1="18" x2="35" y2="18"/>
        </svg>
      </div>
      <p class="tb-title">COD Available</p>
      <p class="tb-sub">Pay on delivery</p>
    </div>

  </div>
</div>
